<style>
  .tf-sp {
    background: var(--tf-bg);
    padding-block: clamp(var(--tf-space-12), 8vw, var(--tf-space-20));
    position: relative;
    overflow: hidden;
  }
  .tf-sp__blob {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 200px;
    background: radial-gradient(ellipse, var(--tf-indigo-50) 0%, transparent 70%);
    opacity: 0.6;
    pointer-events: none;
    z-index: 0;
  }
  .tf-sp__heading {
    text-align: center;
    font-family: var(--tf-font-display);
    font-size: var(--tf-text-2xl);
    font-weight: 700;
    color: var(--tf-text);
    letter-spacing: var(--tf-tracking-tight);
    line-height: var(--tf-leading-snug);
    margin: 0 auto var(--tf-space-10);
    max-width: 680px;
  }
  .tf-sp__heading-accent {
    background: var(--tf-gold-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .tf-sp__logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: clamp(var(--tf-space-6), 4vw, var(--tf-space-12));
    position: relative;
    z-index: 1;
  }
  .tf-sp__logo-item {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 56px;
  }
  .tf-sp__logo-img {
    max-height: 48px;
    max-width: 160px;
    width: auto;
    height: auto;
    display: block;
    filter: grayscale(100%) opacity(0.5);
    transition:
      filter var(--tf-duration-base) var(--tf-ease-out),
      transform var(--tf-duration-base) var(--tf-ease-out);
  }
  .tf-sp__logo-img:hover {
    filter: grayscale(0%) opacity(1);
    transform: translateY(-2px);
  }
  .tf-sp__logo-placeholder {
    height: 48px;
    width: 130px;
    background: var(--tf-ink-100);
    border-radius: var(--tf-radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--tf-font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--tf-ink-400);
    text-transform: uppercase;
    letter-spacing: var(--tf-tracking-wide);
  }
  @media (max-width: 749px) {
    .tf-sp__logo-placeholder {
      width: 100px;
      height: 40px;
    }
  }
</style>

<section class="tf-sp">
  <div class="tf-sp__blob" aria-hidden="true"></div>
  <div class="tf-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="tf-sp__heading tf-reveal">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="tf-sp__logos tf-reveal tf-reveal--delay-1">
      {%- for i in (1..6) -%}
        {%- assign logo_key = 'logo_' | append: i -%}
        <div class="tf-sp__logo-item">
          {%- if section.settings[logo_key] != blank -%}
            {{
              section.settings[logo_key]
              | image_url: width: 320
              | image_tag:
                class: 'tf-sp__logo-img',
                loading: 'lazy',
                widths: '160, 240, 320',
                sizes: '160px',
                alt: ''
            }}
          {%- else -%}
            <div class="tf-sp__logo-placeholder">Logo {{ i }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social proof v2",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Više od 1.000 biznisa već koristi Tapflow za prikupljanje novih recenzija!"
    },
    { "type": "image_picker", "id": "logo_1", "label": "Logo 1" },
    { "type": "image_picker", "id": "logo_2", "label": "Logo 2" },
    { "type": "image_picker", "id": "logo_3", "label": "Logo 3" },
    { "type": "image_picker", "id": "logo_4", "label": "Logo 4" },
    { "type": "image_picker", "id": "logo_5", "label": "Logo 5" },
    { "type": "image_picker", "id": "logo_6", "label": "Logo 6" }
  ],
  "presets": [
    { "name": "Social proof v2" }
  ]
}
{% endschema %}
