<style>
  .tf-ctac {
    padding-block: clamp(var(--tf-space-12), 8vw, var(--tf-space-20));
    background: var(--tf-bg);
    position: relative;
  }
  .tf-ctac__card {
    position: relative;
    background: var(--tf-mesh-indigo);
    border-radius: var(--tf-radius-xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    box-shadow: var(--tf-shadow-xl);
    isolation: isolate;
    min-height: 460px;
  }
  .tf-ctac__card::before {
    content: '';
    position: absolute;
    top: -100px;
    right: -60px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--tf-gold-300) 0%, transparent 65%);
    opacity: 0.30;
    filter: blur(50px);
    z-index: 0;
    pointer-events: none;
  }
  .tf-ctac__card::after {
    content: '';
    position: absolute;
    bottom: -120px;
    right: 20%;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--tf-indigo-400) 0%, transparent 70%);
    opacity: 0.45;
    filter: blur(50px);
    z-index: 0;
    pointer-events: none;
  }
  @media (max-width: 749px) {
    .tf-ctac__card {
      grid-template-columns: 1fr;
      min-height: auto;
    }
  }
  .tf-ctac__image-col {
    position: relative;
    overflow: hidden;
    min-height: 320px;
    z-index: 1;
  }
  .tf-ctac__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    object-position: center;
  }
  .tf-ctac__image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 360px;
    background:
      linear-gradient(135deg, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0) 50%),
      var(--tf-mesh-light);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tf-ink-400);
    font-size: 3rem;
  }
  @media (max-width: 749px) {
    .tf-ctac__image-col {
      order: 1;
      min-height: 260px;
    }
    .tf-ctac__image-placeholder {
      min-height: 260px;
    }
  }
  .tf-ctac__text {
    padding: var(--tf-space-16) var(--tf-space-12);
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 1;
    color: var(--tf-white);
  }
  @media (max-width: 749px) {
    .tf-ctac__text {
      padding: var(--tf-space-10) var(--tf-space-6);
      order: 2;
    }
  }
  .tf-ctac__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--tf-space-2);
    font-size: var(--tf-text-xs);
    font-weight: 600;
    letter-spacing: var(--tf-tracking-wider);
    text-transform: uppercase;
    color: var(--tf-gold-300);
    background: rgba(255, 255, 255, 0.10);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.375rem 0.875rem;
    border-radius: var(--tf-radius-full);
    border: 1px solid rgba(255, 255, 255, 0.15);
    margin-bottom: var(--tf-space-5);
    align-self: flex-start;
  }
  .tf-ctac__heading {
    font-family: var(--tf-font-display);
    font-size: var(--tf-text-3xl);
    font-weight: 800;
    color: var(--tf-white);
    line-height: var(--tf-leading-tight);
    letter-spacing: var(--tf-tracking-tighter);
    margin: 0 0 var(--tf-space-5);
  }
  .tf-ctac__heading-accent {
    background: var(--tf-gold-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: inline-block;
  }
  .tf-ctac__body {
    font-size: var(--tf-text-base);
    color: rgba(255, 255, 255, 0.85);
    line-height: var(--tf-leading-relaxed);
    margin: 0 0 var(--tf-space-8);
    max-width: 46ch;
  }
  .tf-ctac__cta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--tf-space-4);
  }
  .tf-ctac__secondary-text {
    font-size: var(--tf-text-sm);
    color: rgba(255, 255, 255, 0.65);
    font-weight: 500;
  }
</style>

{%- liquid
  assign eyebrow = section.settings.eyebrow
  assign heading_prefix = section.settings.heading_prefix
  assign heading_accent = section.settings.heading_accent
  assign heading_suffix = section.settings.heading_suffix
  assign body_html = section.settings.body
  assign btn_text = section.settings.button_text
  assign btn_link = section.settings.button_link
  assign secondary_text = section.settings.secondary_text
  assign image = section.settings.image
-%}

<section class="tf-ctac tf-section">
  <div class="tf-container">
    <div class="tf-ctac__card tf-reveal">
      <div class="tf-ctac__image-col">
        {%- if image != blank -%}
          {{
            image
            | image_url: width: 1200
            | image_tag:
              class: 'tf-ctac__image',
              loading: 'lazy',
              widths: '480, 720, 960, 1200',
              sizes: '(min-width: 750px) 50vw, 100vw',
              alt: image.alt | default: heading_prefix | escape
          }}
        {%- else -%}
          <div class="tf-ctac__image-placeholder">🖼️</div>
        {%- endif -%}
      </div>

      <div class="tf-ctac__text">
        {%- if eyebrow != blank -%}
          <span class="tf-ctac__eyebrow">{{ eyebrow | escape }}</span>
        {%- endif -%}

        {%- if heading_prefix != blank or heading_accent != blank or heading_suffix != blank -%}
          <h2 class="tf-ctac__heading">
            {{ heading_prefix | escape }}
            {%- if heading_accent != blank -%}
              <span class="tf-ctac__heading-accent">{{ heading_accent | escape }}</span>
            {%- endif -%}
            {{ heading_suffix | escape }}
          </h2>
        {%- endif -%}

        {%- if body_html != blank -%}
          <div class="tf-ctac__body">{{ body_html }}</div>
        {%- endif -%}

        {%- if btn_text != blank -%}
          <div class="tf-ctac__cta-row">
            <a href="{{ btn_link | default: '/collections/all' }}" class="tf-btn tf-btn--gold">
              {{ btn_text | escape }}
            </a>
            {%- if secondary_text != blank -%}
              <span class="tf-ctac__secondary-text">{{ secondary_text | escape }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA card",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (small label above heading)",
      "default": "Stvarni rezultati"
    },
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "Heading — text before accent",
      "default": "Povećajte broj recenzija i do"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading — gold accent word",
      "default": "5X"
    },
    {
      "type": "text",
      "id": "heading_suffix",
      "label": "Heading — text after accent",
      "default": "u prvih 28 dana!"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Na osnovu prosečnih rezultata naših korisnika. Svaki dan ste u kontaktu sa svojim kupcima — ne propuštajte priliku da prikupite više Google recenzija.</p>"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "PORUČITE PLOČICU"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary text (next to button)",
      "default": "Besplatna dostava • Garancija 30 dana"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Card image (product in environment)",
      "info": "Recommended: 1200x900px or larger. Will be cropped to fill left half of card."
    }
  ],
  "presets": [
    { "name": "CTA card" }
  ]
}
{% endschema %}
