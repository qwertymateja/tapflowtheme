<style>
  .tf-faq {
    padding-block: clamp(var(--tf-space-12), 8vw, var(--tf-space-20));
    background: var(--tf-bg);
    position: relative;
  }
  .tf-faq__wrap {
    max-width: 760px;
    margin: 0 auto;
  }
  .tf-faq__list {
    margin-top: clamp(var(--tf-space-8), 5vw, var(--tf-space-12));
    border-top: 1px solid var(--tf-ink-200);
  }
  .tf-faq__item {
    border-bottom: 1px solid var(--tf-ink-200);
  }
  .tf-faq__item summary {
    list-style: none;
    cursor: pointer;
    padding: var(--tf-space-5) 0;
    display: flex;
    align-items: center;
    gap: var(--tf-space-4);
    font-family: var(--tf-font-sans);
    font-size: var(--tf-text-base);
    font-weight: 600;
    color: var(--tf-text);
    transition: color var(--tf-duration-base) var(--tf-ease-out);
  }
  .tf-faq__item summary::-webkit-details-marker { display: none; }
  .tf-faq__item summary:hover { color: var(--tf-indigo-600); }
  .tf-faq__icon {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--tf-indigo-50);
    color: var(--tf-indigo-600);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .tf-faq__icon svg { width: 12px; height: 12px; }
  .tf-faq__q { flex: 1; line-height: var(--tf-leading-snug); }
  .tf-faq__chevron {
    width: 22px;
    height: 22px;
    color: var(--tf-text-muted);
    flex-shrink: 0;
    transition: transform var(--tf-duration-base) var(--tf-ease-out);
  }
  .tf-faq__item[open] .tf-faq__chevron { transform: rotate(180deg); color: var(--tf-indigo-500); }
  .tf-faq__a {
    padding: 0 0 var(--tf-space-5) calc(24px + var(--tf-space-4));
    font-size: var(--tf-text-base);
    color: var(--tf-text-muted);
    line-height: var(--tf-leading-relaxed);
  }
  .tf-faq__a > *:first-child { margin-top: 0; }
  .tf-faq__a > *:last-child { margin-bottom: 0; }
</style>

<section class="tf-faq">
  <div class="tf-container">
    <div class="tf-faq__wrap">
      <div class="tf-section-header--center tf-reveal">
        {%- if section.settings.eyebrow != blank -%}
          <span class="tf-eyebrow">{{ section.settings.eyebrow | escape }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="tf-section-title">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>

      <div class="tf-faq__list tf-reveal tf-reveal--delay-1">
        {%- for block in section.blocks -%}
          <details class="tf-faq__item" {{ block.shopify_attributes }}>
            <summary>
              <span class="tf-faq__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="tf-faq__q">{{ block.settings.question | escape }}</span>
              <svg class="tf-faq__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="tf-faq__a">{{ block.settings.answer }}</div>
          </details>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "class": "section",
  "max_blocks": 20,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Često postavljana pitanja" }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Vaše pitanje?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Vaš odgovor…</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "Kako funkcionišu Tapflow proizvodi?", "answer": "<p>Tapflow proizvodi koriste NFC tehnologiju. Klijent prisloni telefon na pločicu i otvara se direktan link ka vašoj Google stranici za recenzije.</p>" } },
        { "type": "qa", "settings": { "question": "Da li mi je potreban Google my Business profil?", "answer": "<p>Da, potreban vam je aktivan Google Business Profile (besplatno se otvara) da bismo mogli da povežemo Tapflow sa vašom stranicom za recenzije.</p>" } },
        { "type": "qa", "settings": { "question": "Da li su vaši proizvodi kompatibilni sa svim pametnim telefonima?", "answer": "<p>Da, Tapflow radi sa svim telefonima koji podržavaju NFC (svi iPhone XR i noviji, Android telefoni iz poslednjih 8 godina) i sa svim telefonima preko QR koda na pločici.</p>" } },
        { "type": "qa", "settings": { "question": "Kako funkcioniše tehnologija bez kontakta?", "answer": "<p>NFC čip u pločici se aktivira kada klijent prisloni telefon. Telefon očita link i otvara stranicu — bez aplikacije, bez registracije.</p>" } },
        { "type": "qa", "settings": { "question": "Koliko vremena je potrebno da dobijem svoju porudžbinu?", "answer": "<p>Pločice se izrađuju 2-3 radna dana, dostava traje 1-2 dana. Ukupno 3-5 radnih dana od porudžbine.</p>" } },
        { "type": "qa", "settings": { "question": "Imate još pitanja?", "answer": "<p>Kontaktirajte nas na <a href=\"mailto:kontakt@tapflow.shop\">kontakt@tapflow.shop</a> ili preko forme ispod.</p>" } }
      ]
    }
  ]
}
{% endschema %}
