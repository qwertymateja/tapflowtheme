<style>
  .tf-ben {
    padding-block: clamp(var(--tf-space-12), 8vw, var(--tf-space-24));
    background: var(--tf-bg);
    position: relative;
    overflow: hidden;
  }
  .tf-ben__bg-blob {
    position: absolute;
    top: -120px;
    right: -120px;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--tf-indigo-100) 0%, transparent 65%);
    opacity: 0.6;
    filter: blur(40px);
    z-index: 0;
    pointer-events: none;
  }
  .tf-ben__bg-blob--gold {
    position: absolute;
    bottom: -160px;
    left: -100px;
    width: 360px;
    height: 360px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--tf-gold-100) 0%, transparent 70%);
    opacity: 0.55;
    filter: blur(50px);
    z-index: 0;
    pointer-events: none;
  }
  .tf-ben__header {
    text-align: center;
    margin-bottom: clamp(var(--tf-space-10), 6vw, var(--tf-space-16));
    position: relative;
    z-index: 1;
  }
  .tf-ben__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--tf-space-6);
    position: relative;
    z-index: 1;
  }
  @media (max-width: 989px) {
    .tf-ben__grid { grid-template-columns: repeat(2, 1fr); gap: var(--tf-space-5); }
  }
  @media (max-width: 549px) {
    .tf-ben__grid { grid-template-columns: 1fr; gap: var(--tf-space-4); }
  }
  .tf-ben__item {
    background: var(--tf-white);
    border: 1px solid var(--tf-ink-100);
    border-radius: var(--tf-radius-lg);
    padding: var(--tf-space-8) var(--tf-space-6);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--tf-space-4);
    box-shadow: var(--tf-shadow-sm);
    transition:
      transform var(--tf-duration-slow) var(--tf-ease-out),
      box-shadow var(--tf-duration-slow) var(--tf-ease-out),
      border-color var(--tf-duration-base) var(--tf-ease-out);
  }
  .tf-ben__item:hover {
    transform: translateY(-6px);
    box-shadow: var(--tf-shadow-lg);
    border-color: var(--tf-indigo-200);
  }
  .tf-ben__icon-wrap {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--tf-indigo-50);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    flex-shrink: 0;
  }
  .tf-ben__icon-wrap::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: conic-gradient(from 180deg, var(--tf-indigo-300) 0deg, var(--tf-gold-300) 120deg, transparent 240deg, var(--tf-indigo-300) 360deg);
    z-index: -1;
    opacity: 0.5;
    filter: blur(2px);
  }
  .tf-ben__icon {
    width: 32px;
    height: 32px;
    color: var(--tf-indigo-600);
  }
  .tf-ben__title {
    font-family: var(--tf-font-display);
    font-size: var(--tf-text-base);
    font-weight: 700;
    color: var(--tf-text);
    line-height: var(--tf-leading-snug);
    letter-spacing: var(--tf-tracking-tight);
    margin: 0;
  }
  .tf-ben__desc {
    font-size: var(--tf-text-sm);
    color: var(--tf-text-muted);
    line-height: var(--tf-leading-normal);
    margin: 0;
  }
</style>

{%- liquid
  assign show_header = false
  if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank
    assign show_header = true
  endif
-%}

<section class="tf-ben">
  <div class="tf-ben__bg-blob" aria-hidden="true"></div>
  <div class="tf-ben__bg-blob--gold" aria-hidden="true"></div>

  <div class="tf-container">
    {%- if show_header -%}
      <div class="tf-ben__header tf-section-header--center tf-reveal">
        {%- if section.settings.eyebrow != blank -%}
          <span class="tf-eyebrow">{{ section.settings.eyebrow | escape }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="tf-section-title">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="tf-section-subtitle">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="tf-ben__grid">
      {%- for block in section.blocks -%}
        {%- assign delay_class = 'tf-reveal--delay-' | append: forloop.index0 -%}
        {%- if forloop.index0 == 0 -%}{%- assign delay_class = '' -%}{%- endif -%}
        <div class="tf-ben__item tf-reveal {{ delay_class }}">
          <div class="tf-ben__icon-wrap">
            {%- case block.settings.icon -%}
              {%- when 'link' -%}
                <svg class="tf-ben__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              {%- when 'bolt' -%}
                <svg class="tf-ben__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              {%- when 'users' -%}
                <svg class="tf-ben__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              {%- when 'trending' -%}
                <svg class="tf-ben__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              {%- when 'star' -%}
                <svg class="tf-ben__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- when 'shield' -%}
                <svg class="tf-ben__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- when 'check' -%}
                <svg class="tf-ben__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {%- when 'phone' -%}
                <svg class="tf-ben__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
              {%- else -%}
                <svg class="tf-ben__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {%- endcase -%}
          </div>

          {%- if block.settings.title != blank -%}
            <h3 class="tf-ben__title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="tf-ben__desc">{{ block.settings.description | escape }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits v2",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Section header (optional)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Zašto Tapflow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sve što vam treba za više Google recenzija"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Bez aplikacija, bez komplikacija — samo rezultati."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "limit": 8,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "link", "label": "Link / direct access" },
            { "value": "bolt", "label": "Bolt / speed" },
            { "value": "users", "label": "Users / loyalty" },
            { "value": "trending", "label": "Trending up / growth" },
            { "value": "star", "label": "Star / quality" },
            { "value": "shield", "label": "Shield / trust" },
            { "value": "check", "label": "Check / done" },
            { "value": "phone", "label": "Phone / NFC" }
          ],
          "default": "link"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description (optional, 1 line)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits v2",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "link",
            "title": "Direktan pristup stranici za recenzije",
            "description": "Bez koraka, bez čekanja."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "bolt",
            "title": "Brzo i lako za korišćenje",
            "description": "Samo prislonite telefon — gotovo."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "users",
            "title": "Više lojalnih mušterija",
            "description": "Stvarna povezanost sa kupcima."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "trending",
            "title": "Bolje rangiranje na Google-u",
            "description": "Više recenzija = veća vidljivost."
          }
        }
      ]
    }
  ]
}
{% endschema %}
