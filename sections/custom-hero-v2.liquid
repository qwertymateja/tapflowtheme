<style>
  .tf-hero {
    padding: var(--tf-space-8) 0 var(--tf-space-16);
    background: var(--tf-bg);
    position: relative;
    overflow: hidden;
  }
  .tf-hero__card {
    position: relative;
    background: var(--tf-mesh-indigo);
    border-radius: var(--tf-radius-xl);
    display: grid;
    grid-template-columns: 45fr 55fr;
    overflow: hidden;
    min-height: 540px;
    box-shadow: var(--tf-shadow-xl);
    isolation: isolate;
  }
  /* Decorative blobs INSIDE the hero card */
  .tf-hero__card::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -80px;
    width: 360px;
    height: 360px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--tf-gold-300) 0%, transparent 65%);
    opacity: 0.35;
    filter: blur(40px);
    z-index: 0;
    pointer-events: none;
  }
  .tf-hero__card::after {
    content: '';
    position: absolute;
    bottom: -120px;
    left: -80px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--tf-indigo-300) 0%, transparent 70%);
    opacity: 0.5;
    filter: blur(50px);
    z-index: 0;
    pointer-events: none;
  }
  @media (max-width: 749px) {
    .tf-hero__card {
      grid-template-columns: 1fr;
      min-height: auto;
    }
  }
  .tf-hero__text {
    padding: var(--tf-space-16) var(--tf-space-12);
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 749px) {
    .tf-hero__text {
      padding: var(--tf-space-12) var(--tf-space-6) var(--tf-space-8);
      order: 1;
    }
  }
  .tf-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--tf-space-2);
    font-size: var(--tf-text-xs);
    font-weight: 600;
    letter-spacing: var(--tf-tracking-wider);
    text-transform: uppercase;
    color: var(--tf-gold-300);
    background: rgba(255, 255, 255, 0.10);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.375rem 0.875rem;
    border-radius: var(--tf-radius-full);
    border: 1px solid rgba(255, 255, 255, 0.15);
    margin-bottom: var(--tf-space-5);
    align-self: flex-start;
  }
  .tf-hero__heading {
    font-family: var(--tf-font-display);
    font-size: var(--tf-text-4xl);
    font-weight: 800;
    color: var(--tf-white);
    line-height: var(--tf-leading-tight);
    letter-spacing: var(--tf-tracking-tighter);
    margin: 0 0 var(--tf-space-5);
  }
  .tf-hero__heading-accent {
    background: var(--tf-gold-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: inline-block;
  }
  .tf-hero__subheading {
    font-size: var(--tf-text-lg);
    color: rgba(255, 255, 255, 0.85);
    line-height: var(--tf-leading-relaxed);
    margin: 0 0 var(--tf-space-8);
    max-width: 44ch;
  }
  .tf-hero__cta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--tf-space-4);
  }
  .tf-hero__trust {
    margin-top: var(--tf-space-6);
    display: flex;
    align-items: center;
    gap: var(--tf-space-3);
    font-size: var(--tf-text-sm);
    color: rgba(255, 255, 255, 0.80);
    font-weight: 500;
  }
  .tf-hero__stars {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    color: var(--tf-gold-500);
    font-size: var(--tf-text-base);
    line-height: 1;
  }
  .tf-hero__image-col {
    position: relative;
    min-height: 360px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    padding: var(--tf-space-6);
  }
  @media (max-width: 749px) {
    .tf-hero__image-col {
      order: 2;
      min-height: 280px;
      padding: 0 var(--tf-space-6) var(--tf-space-6);
    }
  }
  .tf-hero__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 24px 48px rgba(0, 0, 0, 0.25));
  }
  .tf-hero__placeholder {
    width: 100%;
    height: 100%;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.06);
    border: 2px dashed rgba(255, 255, 255, 0.2);
    border-radius: var(--tf-radius-lg);
    color: rgba(255, 255, 255, 0.4);
    font-size: 4rem;
  }
</style>

<section class="tf-hero">
  <div class="tf-container">
    <div class="tf-hero__card tf-reveal">
      <div class="tf-hero__text">
        {%- if section.settings.trust_text != blank -%}
          <span class="tf-hero__eyebrow">
            <span class="tf-hero__stars">★</span>
            {{ section.settings.trust_text | escape }}
          </span>
        {%- endif -%}

        <h1 class="tf-hero__heading">{{ section.settings.heading | escape }}</h1>

        {%- if section.settings.subheading != blank -%}
          <p class="tf-hero__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}

        <div class="tf-hero__cta-row">
          <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="tf-btn tf-btn--gold">
            {{ section.settings.button_text | escape }}
          </a>
        </div>
      </div>

      <div class="tf-hero__image-col">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1100
            | image_tag:
              class: 'tf-hero__image',
              loading: 'eager',
              fetchpriority: 'high',
              widths: '480, 720, 900, 1100',
              sizes: '(min-width: 750px) 55vw, 100vw'
          }}
        {%- else -%}
          <div class="tf-hero__placeholder">📱</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero v2",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Najbolji i najbrži način da postanete #1 na Google-u!"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Dobijte više recenzija uz Tapflow i privucite više kupaca."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "PORUČITE PLOČICU"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust text (eyebrow above heading)",
      "default": "4.9/5 | Koristi preko 1.000 lokalnih biznisa"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image (product + phone)"
    }
  ],
  "presets": [
    { "name": "Hero v2" }
  ]
}
{% endschema %}
