<style>
  .tf-marquee {
    background: var(--tf-ink-900);
    height: 44px;
    overflow: hidden;
    display: flex;
    align-items: center;
    position: relative;
  }
  .tf-marquee::before,
  .tf-marquee::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }
  .tf-marquee::before {
    left: 0;
    background: linear-gradient(to right, var(--tf-ink-900), transparent);
  }
  .tf-marquee::after {
    right: 0;
    background: linear-gradient(to left, var(--tf-ink-900), transparent);
  }
  .tf-marquee__track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: tf-marquee-scroll 28s linear infinite;
    will-change: transform;
  }
  .tf-marquee__item {
    display: inline-flex;
    align-items: center;
    gap: var(--tf-space-4);
    color: var(--tf-white);
    font-family: var(--tf-font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tf-tracking-wider);
    padding: 0 var(--tf-space-6);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .tf-marquee__dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--tf-gold-500);
    flex-shrink: 0;
  }
  @keyframes tf-marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.333%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .tf-marquee__track { animation: none; }
  }
</style>

{%- assign t = section.settings.marquee_text | default: 'RADI AUTOMATSKI 24/7 · VIŠE GOOGLE RECENZIJA · RADI BEZ APLIKACIJE · POSTANITE #1 NA GOOGLE-U · VIŠE GOOGLE RECENZIJA' -%}
{%- assign items = t | split: '·' -%}

<div class="tf-marquee" aria-hidden="true">
  <div class="tf-marquee__track">
    {%- for repeat in (1..3) -%}
      {%- for item in items -%}
        <span class="tf-marquee__item">
          <span class="tf-marquee__dot"></span>
          {{ item | strip }}
        </span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee bar",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee text (separate items with ·)",
      "default": "RADI AUTOMATSKI 24/7 · VIŠE GOOGLE RECENZIJA · RADI BEZ APLIKACIJE · POSTANITE #1 NA GOOGLE-U · VIŠE GOOGLE RECENZIJA"
    }
  ],
  "presets": [
    { "name": "Marquee bar" }
  ]
}
{% endschema %}
